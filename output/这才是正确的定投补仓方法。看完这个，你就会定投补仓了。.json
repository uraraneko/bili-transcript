      "start": 578.36,
      "end": 580.72,
      "text": "估值在30分位到70分位"
    },
    {
      "start": 580.72,
      "end": 582.0,
      "text": "之間荒謬的時候"
    },
    {
      "start": 582.0,
      "end": 583.68,
      "text": "我們就安心拿著"
    },
    {
      "start": 583.68,
      "end": 585.28,
      "text": "該吃苦惜吃苦惜"
    },
    {
      "start": 585.28,
      "end": 586.64,
      "text": "就當自己買了國債了"
    },
    {
      "start": 586.64,
      "end": 587.72,
      "text": "不荒不躁"
    },
    {
      "start": 587.72,
      "end": 588.72,
      "text": "等著"
    },
    {
      "start": 588.72,
      "end": 590.2,
      "text": "等到將來牛式了"
    },
    {
      "start": 590.2,
      "end": 593.6,
      "text": "估值分位慢慢爬過8090了"
    },
    {
      "start": 593.6,
      "end": 594.92,
      "text": "那時候再考慮一份"
    },
    {
      "start": 594.92,
      "end": 596.6,
      "text": "一份的銅融出場"
    },
    {
      "start": 596.6,
      "end": 597.8,
      "text": "不是一把全賣"
    },
    {
      "start": 597.8,
      "end": 599.28,
      "text": "是一點點退"
    },
    {
      "start": 599.28,
      "end": 601.8,
      "text": "這樣下來你的收益就相當可觀了"
    },
    {
      "start": 601.8,
      "end": 602.44,
      "text": "可以這麼說"
    },
    {
      "start": 602.44,
      "end": 604.0,
      "text": "這個策略能跑音市場上"
    },
    {
      "start": 604.0,
      "end": 606.36,
      "text": "八成非常殺跌的散戶"
    },
    {
      "start": 606.4,
      "end": 607.2,
      "text": "但說實話"
    },
    {
      "start": 607.2,
      "end": 609.32,
      "text": "這個策略的難點不在於技術"
    },
    {
      "start": 609.32,
      "end": 610.56,
      "text": "而在於新興"
    },
    {
      "start": 610.56,
      "end": 611.52,
      "text": "為什麼"
    },
    {
      "start": 611.52,
      "end": 614.36,
      "text": "因為大部分人不願意這麼慢慢來"
    },
    {
      "start": 614.36,
      "end": 616.44,
      "text": "你讓他等三年等五年"
    },
    {
      "start": 616.44,
      "end": 618.44,
      "text": "他恨不得明天抓個漲停"
    },
    {
      "start": 618.44,
      "end": 619.56,
      "text": "總想著快一點"
    },
    {
      "start": 619.56,
      "end": 620.6,
      "text": "再快一點"
    },
    {
      "start": 620.6,
      "end": 622.2,
      "text": "結果就是追漲殺跌"
    },
    {
      "start": 622.2,
      "end": 623.68,
      "text": "反覆被割"
    },
    {
      "start": 623.68,
      "end": 626.4,
      "text": "這也是為什麼八成散戶難以獲利"
    },
    {
      "start": 626.4,
      "end": 627.08,
      "text": "不是不懂"
    },
    {
      "start": 627.08,
      "end": 629.08,
      "text": "是不願意慢慢變負"
    },
    {
      "start": 629.08,
      "end": 630.64,
      "text": "所以校長想說的是"
    },
    {
      "start": 630.64,
      "end": 633.48,
      "text": "你先把整個策略的邏輯想清楚了"
    },
    {
      "start": 633.48,
      "end": 635.16,
      "text": "從心底裡能接受"
    },
    {
      "start": 635.16,
      "end": 636.12,
      "text": "確實能做到"
    },
    {
      "start": 636.16,
      "end": 637.76,
      "text": "再去動手操作"
    },
    {
      "start": 637.76,
      "end": 639.36,
      "text": "這就是孫子賓發獎的"
    },
    {
      "start": 639.36,
      "end": 641.32,
      "text": "先勝而後求戰"
    },
    {
      "start": 641.32,
      "end": 642.08,
      "text": "打仗之前"
    },
    {
      "start": 642.08,
      "end": 644.28,
      "text": "先確保自己利於不敗之地"
    },
    {
      "start": 644.28,
      "end": 646.64,
      "text": "也是巴菲特老爺子說的那句話"
    },
    {
      "start": 646.64,
      "end": 648.64,
      "text": "你可要摸糊的正確"
    },
    {
      "start": 648.64,
      "end": 650.4,
      "text": "也不要精確的錯誤"
    },
    {
      "start": 650.4,
      "end": 652.0,
      "text": "你不需要買在最低點"
    },
    {
      "start": 652.0,
      "end": 653.32,
      "text": "賣在最高點"
    },
    {
      "start": 653.32,
      "end": 655.64,
      "text": "只需要在大概對的區間裡"
    },
    {
      "start": 655.64,
      "end": 657.16,
      "text": "做大概對的事"
    },
    {
      "start": 657.16,
      "end": 658.8,
      "text": "然後靜待花開"
    },
    {
      "start": 658.8,
      "end": 660.76,
      "text": "下期校長繼續給你拆幹貨"
    }
  ]
}